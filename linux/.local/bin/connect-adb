#!/bin/bash

# Check adb ip avahi-browse Exist
for cmd in adb ip avahi-browse; do
	if ! command -v $cmd &>/dev/null; then
		echo "Please install '$cmd' first!" >&2
		exit 1
	fi
done

progressWait() {
	local pid=$1
	local msg=$2
	{
		local pct=0
		while kill -0 "$pid" 2>/dev/null; do
			echo "$pct"
			local remain=$((99 - pct))
			local step=$((remain / 5))
			if [ "$step" -eq 0 ] && [ "$pct" -lt 99 ]; then
				step=1
			fi
			pct=$((pct + step))
			sleep 0.15
		done
		echo 100 # Snap to 100% when the background job completes
	} | dialogProgress "Working" "$msg"
}

dialogDetect() {
	if [ -n "$DISPLAY" ] && command -v zenity &>/dev/null; then
		echo "zenity"
	elif command -v dialog &>/dev/null; then
		echo "dialog"
	elif command -v whiptail &>/dev/null; then
		echo "whiptail"
	else
		echo "Please install zenity, dialog, or whiptail first!" >&2
		exit 1
	fi
}

dialogProgress() {
	if [ "$DIALOG_APP" == "zenity" ]; then
		zenity --progress --title="$1" --text="$2" --width=400 --percentage=0 --auto-close
	elif [ "$DIALOG_APP" == "dialog" ]; then
		dialog --title "$1" --gauge "$2" 6 50 0
	elif [ "$DIALOG_APP" == "whiptail" ]; then
		whiptail --title "$1" --gauge "$2" 6 50 0
	fi
}

dialogMsg() {
	if [ "$DIALOG_APP" == "zenity" ]; then
		zenity --info --title="$1" --text="$2" --width=400
	elif [ "$DIALOG_APP" == "dialog" ]; then
		dialog --title "$1" --msgbox "$2" 8 50
	elif [ "$DIALOG_APP" == "whiptail" ]; then
		whiptail --title "$1" --msgbox "$2" 8 50
	fi
}

dialogInput() {
	if [ "$DIALOG_APP" == "zenity" ]; then
		zenity --entry --title="$1" --text="$2" --width=400
	elif [ "$DIALOG_APP" == "dialog" ]; then
		dialog --title "$1" --inputbox "$2" 8 50 3>&1 1>&2 2>&3
	elif [ "$DIALOG_APP" == "whiptail" ]; then
		whiptail --title "$1" --inputbox "$2" 8 50 3>&1 1>&2 2>&3
	fi
}

dialogYesNo() {
	if [ "$DIALOG_APP" == "zenity" ]; then
		zenity --question --title="$1" --text="$2" --width=450
		return $?
	elif [ "$DIALOG_APP" == "dialog" ]; then
		dialog --title "$1" --yesno "$2" 15 65
		return $?
	elif [ "$DIALOG_APP" == "whiptail" ]; then
		whiptail --title "$1" --yesno "$2" 15 65
		return $?
	fi
}

dialogSelect2x() {
	if [ "$DIALOG_APP" == "zenity" ]; then
		zenity --list --title="$1" --text="$2" --width=600 --height=400 --column="Device" --column="Action" "${@:3}" 2>/dev/null
	elif [ "$DIALOG_APP" == "dialog" ]; then
		dialog --title "$1" --menu "$2" 15 60 4 "${@:3}" 3>&1 1>&2 2>&3
	elif [ "$DIALOG_APP" == "whiptail" ]; then
		whiptail --title "$1" --menu "$2" 15 60 4 "${@:3}" 3>&1 1>&2 2>&3
	fi
}

cleanUp() {
	trap 'rm -f "$TMP_OUT"; exit 0' INT TERM EXIT
	adb start-server &>/dev/null
	local offline_devices=$(adb devices | grep -E '\boffline\b' | awk '{print $1}')
	for dev in $offline_devices; do
		adb disconnect "$dev" &>/dev/null
	done
}

scanAndroidDevices() {
	(
		>"$TMP_OUT"

		local avahi_conn=$(avahi-browse -rtp _adb-tls-connect._tcp 2>&1)
		local avahi_pair=$(avahi-browse -rtp _adb-tls-pairing._tcp 2>&1)

		if [[ "$avahi_conn" == *"Daemon not running"* ]]; then
			echo "DAEMON_ERROR" >"$TMP_OUT"
		else
			local mdns_conn=$(echo "$avahi_conn" | grep "^=" | awk -F';' '{print $8":"$9}')
			for dev in $mdns_conn; do
				echo "$dev|Connect" >>"$TMP_OUT"
			done

			local mdns_pair=$(echo "$avahi_pair" | grep "^=" | awk -F';' '{print $8":"$9}')
			for dev in $mdns_pair; do
				echo "$dev|Pair" >>"$TMP_OUT"
			done
		fi
	) &
	progressWait $! "Scanning Services..."
}

checkAvahiDaemon() {
	if grep -q "DAEMON_ERROR" "$TMP_OUT"; then
		dialogMsg "Avahi Daemon Offline" "Avahi Daemon service offline.\nPlease start the Avahi Daemon."
		clear
		echo "Avahi Daemon service offline. Please start the Avahi Daemon."
		exit 1
	fi
}

buildMenuOptions() {
	local -a raw_menu_options=() clean_menu_options=() seen=""

	while IFS="|" read -r ip_port desc; do
		if [ -n "$ip_port" ] && [ "$ip_port" != "DAEMON_ERROR" ]; then
			raw_menu_options+=("$ip_port" "$desc")
		fi
	done <"$TMP_OUT"

	for ((i = 0; i < ${#raw_menu_options[@]}; i += 2)); do
		ip_port="${raw_menu_options[$i]}"
		desc="${raw_menu_options[$i + 1]}"

		if [[ ! " $seen " =~ " $ip_port " ]]; then
			clean_menu_options+=("$ip_port" "$desc")
			seen+="$ip_port "
		fi
	done
	echo "${clean_menu_options[@]}"
}

pairDevice() {
	local device="$1"
	local pin=$(dialogInput "Pairing $device" "Enter the 6-digit Wi-Fi pairing code:")

	if [ -z "$pin" ]; then
		clear
		echo "Pairing cancelled."
		exit 0
	fi

	(adb pair "$device" "$pin" >"$TMP_OUT" 2>&1) &
	progressWait $! "Pairing $device..."
	local pair_out=$(<"$TMP_OUT")

	if [[ "$pair_out" =~ "Successfully paired" ]]; then
		dialogMsg "Pairing Successful" "${pair_out^}"
		exec "$0"
	else
		dialogMsg "Pairing Failed" "${pair_out^}"
		clear
		echo "$pair_out"
		exit 1
	fi
}

connectDevice() {
	local device="$1"

	adb disconnect "$device" &>/dev/null

	(adb connect "$device" >"$TMP_OUT" 2>&1) &
	progressWait $! "Connecting to $device..."
	local output=$(<"$TMP_OUT")

	if [[ "$output" =~ "failed to connect to" ]] || [[ "$output" =~ "failed to authenticate" ]] || [[ "$output" =~ "Connection refused" ]]; then
		if dialogYesNo "Connection Failed" "${output^}\n\n1. Tap 'Pair device with pairing code'.\n2. Tap 'Yes'."; then
			exec "$0"
		else
			clear
			echo "$output"
			exit 1
		fi
	else
		devices_out=$(adb devices | tail -n +2 | grep -v '^$')
		if [ -z "$devices_out" ]; then
			devices_out=""
		fi
		dialogMsg "Connection Successful" "${output^}\n\n$devices_out"
		clear
	fi
}

# --------------------------------------

TMP_OUT=$(mktemp)
DIALOG_APP=$(dialogDetect) || exit 1

cleanUp
scanAndroidDevices
checkAvahiDaemon

MENU_OPTIONS=$(buildMenuOptions)

if [ -z "$MENU_OPTIONS" ]; then
	dialogMsg "No Devices Found" "No Android devices found on the network."
	clear
	echo "No Android devices found."
	exit 0
fi

# Display Selection Menu
CHOICE=$(dialogSelect2x "ADB Wireless Connect" "Select Android Device:" $MENU_OPTIONS)

if [ -z "$CHOICE" ]; then
	clear
	echo "Operation cancelled by user."
	exit 0
fi

# Check if the selected IP:PORT belongs to the Pairing list
if grep -q "^$CHOICE|Pair$" "$TMP_OUT"; then
	pairDevice "$CHOICE"
else
	connectDevice "$CHOICE"
fi
