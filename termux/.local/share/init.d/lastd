#!/data/data/com.termux/files/usr/bin/bash

### BEGIN INIT INFO
# Provides:          lastd
# Required-Start:    $local_fs
# Required-Stop:     $local_fs
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: Save and restore last directory
# ### END INIT INFO

LASTD_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/termux/.lastd"

start() {
	if [ -f "$LASTD_FILE" ]; then
		. "$LASTD_FILE"
		rm -f "$LASTD_FILE"
		echo "Restored directory: $PWD"
	else
		echo "No saved directory found."
	fi
}

stop() {
	if [ -f "$LASTD_FILE" ]; then
		rm -f "$LASTD_FILE"
		echo "Cleared saved directory state."
	else
		echo "No saved directory to clear."
	fi
}

status() {
	if [ -f "$LASTD_FILE" ]; then
		echo "Saved directory exists: $(cat "$LASTD_FILE")"
	else
		echo "No saved directory state."
	fi
}

save() {
	local target_dir="$1"
	if [ -n "$target_dir" ] && [ -d "$target_dir" ]; then
		mkdir -p "$(dirname "$LASTD_FILE")"
		printf "cd %q\n" "$target_dir" >"$LASTD_FILE"
		echo "Saved directory: $target_dir"
	else
		echo "Error: Please provide a valid directory path to save."
		return 1
	fi
}

case "$1" in
start) start ;;
stop) stop ;;
status) status ;;
save) save "$2" ;;
*) echo "Usage: source $0 {start|stop|status} OR $0 save '/path/to/dir'" ;;
esac
